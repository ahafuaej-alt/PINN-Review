{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ahafuaej-alt.github.io/PINN-Review/data/papers-master.schema.json",
  "title": "PINN Review Atlas canonical paper dataset",
  "type": "object",
  "required": ["metadata", "papers"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["schema_version", "dataset_version", "last_updated", "record_count", "sources"],
      "properties": {
        "schema_version": { "const": "1.0.0" },
        "dataset_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "last_updated": { "type": "string", "format": "date" },
        "record_count": { "const": 853 }
      }
    },
    "papers": {
      "type": "array",
      "minItems": 853,
      "maxItems": 853,
      "items": {
        "type": "object",
        "required": ["id", "title", "citation", "doi", "publisher_url", "venue", "year", "access", "countries", "provenance", "last_updated"],
        "properties": {
          "id": { "type": "integer", "minimum": 1, "maximum": 853 },
          "title": { "type": "string", "minLength": 1 },
          "citation": { "type": "string", "minLength": 1 },
          "doi": { "type": ["string", "null"] },
          "publisher_url": { "type": ["string", "null"], "format": "uri" },
          "venue": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "type": { "enum": ["journal", "preprint", "conference_journal", "conference", "presentation", "conference_book", "book", "chapter", "website", "thesis", "patent", "standard", "software", "magazine", "report", "other", "unknown"] }
            },
            "additionalProperties": false
          },
          "bibliographic": {
            "type": "object",
            "description": "Optional structured MDPI ACS reference elements. Legacy records remain valid and are progressively structured when evidence-backed updates are accepted.",
            "properties": {
              "authors": { "type": "string", "minLength": 1 },
              "editors": { "type": "string", "minLength": 1 },
              "journal_abbreviation": { "type": "string", "minLength": 1 },
              "volume": { "type": "string", "minLength": 1 },
              "issue": { "type": "string", "minLength": 1, "description": "Stored metadata; omitted from ordinary MDPI journal references." },
              "pages": { "type": "string", "minLength": 1 },
              "article_number": { "type": "string", "minLength": 1 },
              "edition": { "type": "string", "minLength": 1 },
              "book_title": { "type": "string", "minLength": 1 },
              "chapter": { "type": "string", "minLength": 1 },
              "publisher": { "type": "string", "minLength": 1 },
              "city": { "type": "string", "minLength": 1 },
              "country": { "type": "string", "minLength": 1 },
              "conference_name": { "type": "string", "minLength": 1 },
              "conference_location": { "type": "string", "minLength": 1 },
              "conference_country": { "type": "string", "minLength": 1 },
              "conference_date": { "type": "string", "minLength": 1 },
              "abstract_number": { "type": "string", "minLength": 1 },
              "paper_number": { "type": "string", "minLength": 1 },
              "thesis_level": { "type": "string", "minLength": 1 },
              "institution": { "type": "string", "minLength": 1 },
              "access_date": { "type": "string", "minLength": 1 },
              "publication_date": { "type": "string", "minLength": 1 },
              "patent_number": { "type": "string", "minLength": 1 },
              "standard_number": { "type": "string", "minLength": 1 },
              "software_version": { "type": "string", "minLength": 1 },
              "software_description": { "type": "string", "minLength": 1 },
              "report_number": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "year": { "type": ["integer", "null"], "minimum": 1800, "maximum": 2100 },
          "access": { "enum": ["Open access", "Subscription", "Not verified"] },
          "countries": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "overrides": {
            "type": "object",
            "properties": { "realm_year": { "type": "integer", "minimum": 1800, "maximum": 2100 } },
            "additionalProperties": false
          },
          "provenance": { "type": "object" },
          "last_updated": { "type": "string", "format": "date" }
        },
        "additionalProperties": false
      }
    }
  }
}
